# ==============================================================================
# ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to `.env` or `.env.local` and fill in the values.
# Example:
#   cp .env.example .env.local

# ── CROO SDK KEY ────────────────────────────────────────────────────
# Your CROO Agent SDK key (croo_sk_...) from the CROO Dashboard.
# Required in LIVE mode. Omit only when running with CROO_MOCK=true.
CROO_SDK_KEY=

# ── LITMUS SERVICE ID ───────────────────────────────────────────────
# The registered service ID for your "Output Grading" service.
# Register the service in the CROO Dashboard, then paste its ID here.
LITMUS_SERVICE_ID=

# ── LLM GRADING KEYS ────────────────────────────────────────────────
# Litmus grades with an LLM judge at temperature 0. Provide at least one.
# If both are set, Litmus runs a two-model "tribunal" with a tiebreaker.
# If neither is set, Litmus falls back to deterministic mock grading.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── MOCK MODE (optional) ────────────────────────────────────────────
# Set to true for offline development — no USDC spent, no WebSocket opened.
# CROO_MOCK=true
