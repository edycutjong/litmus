{
  "name": "dorahacks-croo-litmus",
  "version": "0.1.0",
  "description": "Output-grading quality gate agent — grades any deliverable 0-100 with a rubric, on-chain",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --silent --coverage",
    "stability": "tsx scripts/stability.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=high || true",
    "ci": "npm run audit && npm run lint && npm run typecheck && npm run test:coverage"
  },
  "keywords": [
    "croo",
    "agent",
    "a2a",
    "grading",
    "quality"
  ],
  "license": "MIT",
  "dependencies": {
    "@edycutjong/croo-core": "^0.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "license-checker": "^25.0.1",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "ws": "^8.20.1"
  }
}